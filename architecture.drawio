<mxfile host="app.diagrams.net" agent="claude-ci-agent" version="24.0.0">
  <diagram id="ci-arch" name="CI Architecture">
    <mxGraphModel dx="1100" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="826" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Multi-Agent / OTel CI Architecture" style="text;html=1;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;fontColor=#25e8ff;fontFamily=Orbitron;" vertex="1" parent="1">
          <mxGeometry x="360" y="20" width="440" height="40" as="geometry" />
        </mxCell>

        <!-- GitLab CI -->
        <mxCell id="gitlab" value="GitLab CI&#10;&#10;.gitlab-ci.yml&#10;$GITLAB_CI == true&#10;OpenShift GitLab Runner" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#071018;strokeColor=#25e8ff;fontColor=#cdeef5;fontFamily=Rajdhani;align=center;verticalAlign=top;spacingTop=8;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="120" width="240" height="120" as="geometry" />
        </mxCell>

        <!-- GitHub Actions -->
        <mxCell id="github" value="GitHub Actions&#10;&#10;.github/workflows/*.yml&#10;$GITHUB_ACTIONS == true&#10;Hosted / self-hosted runner" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#071018;strokeColor=#25e8ff;fontColor=#cdeef5;fontFamily=Rajdhani;align=center;verticalAlign=top;spacingTop=8;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="300" width="240" height="120" as="geometry" />
        </mxCell>

        <!-- Sandbox container -->
        <mxCell id="sandbox" value="Rootless, Unprivileged Podman Sandbox" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#05101a;strokeColor=#25e8ff;fontColor=#25e8ff;fontFamily=Orbitron;align=center;verticalAlign=top;spacingTop=10;fontStyle=1;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="440" y="120" width="360" height="300" as="geometry" />
        </mxCell>

        <!-- Claude agent inside sandbox -->
        <mxCell id="agent" value="Claude CI Agent&#10;&#10;Build (podman build)&#10;Test (npm test / pytest)&#10;Lint (npm run lint)&#10;Atomic git commits" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0a1c26;strokeColor=#25e8ff;fontColor=#e7feff;fontFamily=Rajdhani;align=center;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="470" y="170" width="300" height="120" as="geometry" />
        </mxCell>

        <!-- OTel flags -->
        <mxCell id="otelflags" value="Telemetry flags&#10;CLAUDE_CODE_ENABLE_TELEMETRY=1&#10;OTEL_LOG_TOOL_CONTENT=1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#071018;strokeColor=#25e8ff;fontColor=#cdeef5;fontFamily=Rajdhani;align=center;verticalAlign=middle;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="470" y="310" width="300" height="80" as="geometry" />
        </mxCell>

        <!-- OTel Collector sidecar -->
        <mxCell id="otel" value="OTel Collector (per team)&#10;&#10;localhost:4318 / team svc&#10;(secret scrubbing)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#08161e;strokeColor=#25e8ff;fontColor=#cdeef5;fontFamily=Rajdhani;align=center;verticalAlign=top;spacingTop=8;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="880" y="170" width="220" height="100" as="geometry" />
        </mxCell>

        <!-- Elastic -->
        <mxCell id="elastic" value="Elastic&#10;&#10;claude-agent-&lt;team&gt;-*&#10;per-team index / RBAC" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#08161e;strokeColor=#25e8ff;fontColor=#cdeef5;fontFamily=Rajdhani;align=center;verticalAlign=top;spacingTop=8;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="880" y="320" width="220" height="100" as="geometry" />
        </mxCell>

        <!-- Edges -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#25e8ff;" edge="1" parent="1" source="gitlab" target="sandbox">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#25e8ff;" edge="1" parent="1" source="github" target="sandbox">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="OTLP events" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#25e8ff;fontColor=#9af6ff;fontFamily=Rajdhani;" edge="1" parent="1" source="sandbox" target="otel">
          <mxGeometry relative="1" as="geometry" />
