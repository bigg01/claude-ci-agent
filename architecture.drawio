        <mxCell id="e4" value="export" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#25e8ff;fontColor=#9af6ff;fontFamily=Rajdhani;" edge="1" parent="1" source="otel" target="elastic">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- LLM Gateway (optional) -->
        <mxCell id="gateway" value="LLM Gateway (optional)&#10;&#10;Prompt caching · Guardrails&#10;ANTHROPIC_BASE_URL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1206;strokeColor=#ff9d2e;fontColor=#ff9d2e;fontFamily=Rajdhani;align=center;verticalAlign=middle;fontStyle=1;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="440" y="470" width="360" height="90" as="geometry" />
        </mxCell>

        <!-- Creation model (Agent personality) -->
        <mxCell id="anthropic" value="Creation model&#10;&#10;Anthropic API&#10;claude-opus-4-8" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#071018;strokeColor=#25e8ff;fontColor=#e7feff;fontFamily=Rajdhani;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="470" y="620" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- Review model (Advisor personality) — independent model or vendor -->
        <mxCell id="reviewer" value="Review model / vendor&#10;&#10;independent — a different&#10;model or vendor" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#160a1f;strokeColor=#b388ff;fontColor=#d6c3ff;fontFamily=Rajdhani;align=center;verticalAlign=middle;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="780" y="620" width="240" height="80" as="geometry" />
        </mxCell>

        <!-- Edges: agent -> gateway -> creation / review models -->
        <mxCell id="e5" value="messages" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#ff9d2e;fontColor=#ffc785;fontFamily=Rajdhani;" edge="1" parent="1" source="agent" target="gateway">
          <mxGeometry relative="1" as="geometry" />
